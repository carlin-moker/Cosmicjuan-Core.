require('dotenv').config();
const { ethers } = require('ethers');
const axios = require('axios');

async function initiateCore() {
    console.log("--- INICIANDO NÚCLEO SOBERANO: COSMICJUAN.BLOCKCHAIN ---");
    console.log("--- SINERGIA CUÁNTICA-NEURONAL ACTIVADA ---");

    try {
        // Validación de Entorno Soberano
        if (!process.env.CJ_RPC_URL || !process.env.CJ_PRIVATE_KEY) {
            throw new Error("ERROR: Entorno no definido. Acceso soberano bloqueado.");
        }

        // Conexión a la red física-matemática independiente
        const provider = new ethers.providers.JsonRpcProvider(process.env.CJ_RPC_URL);
        const wallet = new ethers.Wallet(process.env.CJ_PRIVATE_KEY, provider);

        console.log("Estado: Nodo conectado. Red62 en sincronía.");
        
        // Protocolo de validación neuropinal
        return { provider, wallet };

    } catch (error) {
        console.error("Fallo de integridad en el núcleo:", error.message);
    }
}

module.exports = { initiateCore };
